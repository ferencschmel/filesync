{
  "name": "synctool",
  "version": "1.0.0",
  "description": "Serverless file/directory sync tool using hash-based change detection",
  "main": "dist/index.js",
  "bin": {
    "synctool": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:clean": "rimraf dist && tsc -p tsconfig.build.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "start": "node dist/index.js",
    "start:config1": "node dist/index.js --config config1.json sync",
    "start:config2": "node dist/index.js --config config2.json sync",
    "sync": "node dist/index.js sync",
    "watch": "node dist/index.js watch",
    "package:win": "pkg dist/index.js --target node18-win-x64 --output release/synctool-win-x64.exe",
    "package:mac-x64": "pkg dist/index.js --target node18-macos-x64 --output release/synctool-macos-x64",
    "package:mac-arm64": "pkg dist/index.js --target node18-macos-arm64 --output release/synctool-macos-arm64",
    "package:linux": "pkg dist/index.js --target node18-linux-x64 --output release/synctool-linux-x64",
    "package:all": "npm run package:win && npm run package:mac-x64 && npm run package:mac-arm64 && npm run package:linux"
  },
  "dependencies": {
    "basic-ftp": "^5.0.5",
    "chokidar": "^3.6.0",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "@yao-pkg/pkg": "^5.13.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  },
  "pkg": {
    "assets": ["dist/**/*"],
    "targets": ["node18-win-x64", "node18-macos-x64", "node18-macos-arm64", "node18-linux-x64"],
    "outputPath": "release"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
